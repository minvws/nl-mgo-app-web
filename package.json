    "simple-git-hooks": {
        "commit-msg": "pnpm commitlint --edit ${1}"
    },
    "commitlint": {
        "extends": [
            "@commitlint/config-conventional"
        ],
        "rules": {
            "scope-enum": [
                2,
                "always",
                [
                    "repo",
                    "ci",
                    "hcim-api",
                    "hcim-labels",
                    "mgo",
                    "mgo-e2e",
                    "config",
                    "data-services",
                    "fhir",
                    "fhir-client",
                    "hcim",
                    "hcim-parse",
                    "hcim-ui",
                    "logging",
                    "ts-json-schema",
                    "intl",
                    "ui",
                    "utils",
                    "org-search",
                    "org-search-api"
                ]
            ]
        }
    },
