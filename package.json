{
    "private": true,
    "license": "UNLICENSED",
    "packageManager": "pnpm@8.13.1",
    "engines": {
        "pnpm": "^8.0.0"
    },
    "scripts": {
        "dev": "pnpm run --dir apps/react dev",
        "test": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
        "lint:fix": "eslint . --ext ts,tsx --fix",
        "storybook": "pnpm run --dir packages/react-ui dev",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "devDependencies": {
        "@commitlint/cli": "^19.0.3",
        "@commitlint/config-conventional": "^19.0.3",
        "@tanstack/eslint-plugin-query": "^5.20.1",
        "@typescript-eslint/eslint-plugin": "^7.1.1",
        "@typescript-eslint/parser": "^7.1.1",
        "@vitest/coverage-v8": "^1.3.1",
        "eslint": "^8.57.0",
        "eslint-plugin-import": "^2.29.1",
        "eslint-plugin-react": "^7.34.0",
        "eslint-plugin-react-hooks": "^4.6.0",
        "eslint-plugin-react-refresh": "^0.4.5",
        "eslint-plugin-sonarjs": "^0.24.0",
        "prettier": "^3.2.5",
        "prettier-plugin-tailwindcss": "^0.5.12",
        "simple-git-hooks": "^2.10.0",
        "vitest": "^1.3.1"
    },
    "simple-git-hooks": {
        "commit-msg": "pnpm commitlint --edit ${1}"
    },
    "commitlint": {
        "extends": [
            "@commitlint/config-conventional"
        ]
    },
    "pnpm": {
        "auditConfig": {
            "ignoreCvesComments (non-standard key)": {
                "CVE-2023-42282": "This vulnerability in the npm package 'ip' doesn't affect us, as the dependency that uses it  (@storybook/core-server) is only used during development and doesn't call into the vulnerable code. See https://github.com/minvws/nl-mgo-app-web-private/pull/53. Can be removed after https://github.com/storybookjs/storybook/issues/26014 is resolved."
            },
            "ignoreCves": [
                "CVE-2023-42282"
            ]
        }
    }
}
