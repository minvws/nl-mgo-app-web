{
    "extends": "../../tsconfig.base.lib.json",
    "compilerOptions": {
        "baseUrl": ".",
        "rootDir": "src",
        "outDir": "dist",
        "tsBuildInfoFile": "../../out-tsc/mgo-fhir/tsconfig.lib.tsbuildinfo",
        "emitDeclarationOnly": false,
        "types": [],
        "lib": ["es2022"],
        "paths": {
            "fhir/r3": ["node_modules/@types/fhir/r3.d.ts"],
            "fhir/r4": ["node_modules/@types/fhir/r4.d.ts"]
