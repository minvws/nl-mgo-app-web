{
    "private": true,
    "license": "UNLICENSED",
    "packageManager": "pnpm@8.13.1",
    "engines": {
        "pnpm": "^8.0.0"
    },
    "scripts": {
        "dev": "pnpm run --dir apps/mgo dev",
        "test": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
        "lint:fix": "eslint . --ext ts,tsx --fix",
        "check-types": "tsc --version && pnpm run -r check-types",
        "storybook": "pnpm run --dir packages/mgo-ui dev",
        "i18n": "pnpm run --dir apps/mgo messages:extract",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "pr": "pnpm audit && pnpm run format && pnpm run lint:fix && pnpm run check-types && pnpm run i18n && vitest run --coverage"
    },
    "devDependencies": {
        "@commitlint/cli": "^19.2.0",
        "@commitlint/config-conventional": "^19.1.0",
        "@tanstack/eslint-plugin-query": "^5.27.7",
        "@typescript-eslint/eslint-plugin": "^7.2.0",
        "@typescript-eslint/parser": "^7.2.0",
        "@vitest/coverage-v8": "^1.3.1",
        "eslint": "^8.57.0",
        "eslint-plugin-import": "^2.29.1",
        "eslint-plugin-react": "^7.34.1",
        "eslint-plugin-react-hooks": "^4.6.0",
        "eslint-plugin-react-refresh": "^0.4.6",
        "eslint-plugin-sonarjs": "^0.24.0",
        "prettier": "^3.2.5",
        "prettier-plugin-tailwindcss": "^0.5.12",
        "simple-git-hooks": "^2.10.0",
        "typescript": "^5.4.3",
        "vitest": "^1.3.1"
    },
    "simple-git-hooks": {
        "commit-msg": "pnpm commitlint --edit ${1}"
    },
    "commitlint": {
        "extends": [
            "@commitlint/config-conventional"
        ]
    },
    "pnpm": {
        "auditConfig": {
            "non-standard-ignore-cves-comments": {
                "CVE-2024-29415": "Only affeccts devDependency storybook, waiting for the fix to be released. https://github.com/storybookjs/storybook/pull/27529"
            },
            "ignoreCves": [
                "CVE-2024-29415"
            ]
        }
    }
}
