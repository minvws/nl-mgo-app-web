{
    "name": "@minvws/mgo-source",
    "private": true,
    "license": "UNLICENSED",
    "packageManager": "pnpm@9.13.2",
    "scripts": {
        "preview": "nx run mgo-mgo:preview",
        "dev": "nx run mgo-mgo:dev",
        "test": "vitest",
        "test:hcim:update": "vitest --project @minvws/mgo-hcim --update",
        "test:coverage": "vitest run --coverage --coverage.reportOnFailure",
        "lint": "nx run-many -t lint",
        "lint:fix": "pnpm run -r lint --fix",
        "typecheck": "nx run-many -t typecheck",
        "storybook": "pnpm run --dir packages/ui dev",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "messages:update": "pnpm run --dir packages/intl messages:update",
        "pr": "pnpm audit && pnpm run format && pnpm run lint:fix && pnpm run lint && pnpm run check-types && vitest run --coverage",
        "e2e": "pnpm run --dir apps/mgo-e2e e2e",
        "graph": "pnpm exec nx graph"
    },
