{
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "projectType": "application",

    "targets": {
        "build-mobile": {
            "executor": "nx:run-commands",
            "options": {
                "commands": [
                    "nx run @minvws/mgo-hcim-api:build-api",
                    "nx run @minvws/mgo-hcim-api:build-api-types"
                ]
            },
            "parallel": false
        },
        "build-api": {
            "cache": true,
            "executor": "@nx/vite:build",
            "dependsOn": ["^typecheck", "^build"],
            "options": {
                "configFile": "apps/hcim-api/vite.api.config.ts",
                "outputPath": "{projectRoot}/build/js"
            }
        },
        "build-api-types": {
            "cache": true,
            "executor": "@nx/vite:build",
            "dependsOn": ["^typecheck", "^build"],
            "options": {
                "configFile": "apps/hcim-api/vite.api.types.config.ts",
                "outputPath": "{projectRoot}/build/schema/typescript"
            }
        }
    }
}
